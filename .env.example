# ===== Қазтілші — API Keys =====
# Минимум один ключ обязателен. Чем больше ключей — тем больше движков, тем лучше качество.

# OpenAI GPT-4o (рекомендуется — высшее качество)
OPENAI_API_KEY=sk-...

# HuggingFace (для модели issai/tilmash, казахская open-source модель)
HUGGINGFACE_API_KEY=hf_...

# DeepL (бета-поддержка казахского)
DEEPL_API_KEY=...

# Yandex Cloud Translate v2
YANDEX_API_KEY=...

# ===== Server =====
PORT=5000
NODE_ENV=production
